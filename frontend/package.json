{
  "name": "cosmetic-workshop-os-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && node scripts/dev-server.mjs dist",
    "build": "tsc -p tsconfig.json && node scripts/build.mjs",
    "preview": "npm run build && node scripts/dev-server.mjs dist",
    "test:form-validation": "rm -rf dist-tests/form-validation && tsc -p tsconfig.test.form-validation.json && node --test test/form-validation.test.mjs",
    "test:targeted-validation-update": "rm -rf dist-tests/targeted-validation-update && tsc -p tsconfig.test.targeted-validation-update.json && node --test test/targeted-validation-update.test.mjs",
    "test:order-mutation-lifecycle": "rm -rf dist-tests/order-mutation-lifecycle && tsc -p tsconfig.test.order-mutation-lifecycle.json && node --test test/order-mutation-lifecycle.test.mjs",
    "test:order-readiness-presentation": "rm -rf dist-tests/order-readiness-presentation && tsc -p tsconfig.test.order-readiness-presentation.json && node --test test/order-readiness-presentation.test.mjs",
    "test:dashboard-onboarding-feedback": "rm -rf dist-tests/dashboard-onboarding-feedback && tsc -p tsconfig.test.dashboard-onboarding-feedback.json && node --test test/dashboard-onboarding-feedback.test.mjs",
    "test:help-passive-regression": "rm -rf dist-tests/help-passive-regression && tsc -p tsconfig.test.help-passive-regression.json && node --test test/help-passive-regression.test.mjs",
    "test:alerts-feedback": "rm -rf dist-tests/alerts-feedback && tsc -p tsconfig.test.alerts-feedback.json && node --test test/alerts-feedback.test.mjs",
    "test:purchase-suggestions-feedback": "rm -rf dist-tests/purchase-suggestions-feedback && tsc -p tsconfig.test.purchase-suggestions-feedback.json && node --test test/purchase-suggestions-feedback.test.mjs",
    "test:local-artifacts-reports-feedback": "rm -rf dist-tests/local-artifacts-reports-feedback && tsc -p tsconfig.test.local-artifacts-reports-feedback.json && node --test test/local-artifacts-reports-feedback.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
